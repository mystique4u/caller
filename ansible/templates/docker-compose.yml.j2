services:
  traefik:
    image: traefik:v2.11
    container_name: traefik
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "8080:8080"
      - "8448:8448"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /opt/services/traefik/traefik.toml:/etc/traefik/traefik.toml:ro
      - /opt/services/traefik/dynamic:/etc/traefik/dynamic:ro
      - /opt/services/traefik/acme:/acme
    networks:
      - services
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.dashboard.rule=Host(`{{ domain_name }}`) && (PathPrefix(`/api`) || PathPrefix(`/dashboard`))"
      - "traefik.http.routers.dashboard.service=api@internal"
      - "traefik.http.routers.dashboard.entrypoints=websecure"
      - "traefik.http.routers.dashboard.tls.certresolver=letsencrypt"

  wireguard-ui:
    image: ngoduykhanh/wireguard-ui:{{ wireguard_ui_version }}
    container_name: wireguard-ui
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    privileged: true
    environment:
      - WGUI_USERNAME=admin
      - WGUI_PASSWORD=admin
      - WGUI_SESSION_SECRET={{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}
      - WGUI_ENDPOINT_ADDRESS=vpn.{{ domain_name }}
      - WGUI_DNS=1.1.1.1,1.0.0.1
      - WGUI_MTU=1420
      - WGUI_PERSISTENT_KEEPALIVE=25
      - WGUI_SERVER_INTERFACE_ADDRESSES=10.0.0.1/24
      - WGUI_SERVER_LISTEN_PORT={{ wireguard_port }}
      - WGUI_SERVER_POST_UP_SCRIPT=/etc/wireguard/wg-nat.sh
      - WGUI_SERVER_POST_DOWN_SCRIPT=iptables -D FORWARD -i wg0 -j ACCEPT; iptables -D FORWARD -o wg0 -j ACCEPT; iptables -t nat -D POSTROUTING -o eth0 -j MASQUERADE; ip6tables -D FORWARD -i wg0 -j ACCEPT; ip6tables -t nat -D POSTROUTING -o eth0 -j MASQUERADE
    volumes:
      - /opt/services/wireguard-ui:/app/db
      - /etc/wireguard:/etc/wireguard

  jitsi-web:
    image: "{{ jitsi_web_image }}"
    container_name: jitsi-web
    restart: unless-stopped
    environment:
      - ENABLE_AUTH=1
      - ENABLE_GUESTS=0
      - AUTH_TYPE=internal
      - PUBLIC_URL=https://meet.{{ domain_name }}
      - XMPP_DOMAIN=meet.jitsi
      - XMPP_AUTH_DOMAIN=auth.meet.jitsi
      - XMPP_BOSH_URL_BASE=http://jitsi-prosody:5280
      - XMPP_MUC_DOMAIN=muc.meet.jitsi
      - JVB_TCP_HARVESTER_DISABLED=true
    networks:
      - services
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.jitsi.rule=Host(`meet.{{ domain_name }}`)"
      - "traefik.http.routers.jitsi.entrypoints=websecure"
      - "traefik.http.services.jitsi.loadbalancer.server.port=80"
      - "traefik.http.services.jitsi.loadbalancer.server.scheme=http"
      - "traefik.http.routers.jitsi.tls.certresolver=letsencrypt"

  jitsi-prosody:
    image: "{{ jitsi_prosody_image }}"
    container_name: jitsi-prosody
    restart: unless-stopped
    environment:
      - XMPP_DOMAIN=meet.jitsi
      - XMPP_AUTH_DOMAIN=auth.meet.jitsi
      - XMPP_MUC_DOMAIN=muc.meet.jitsi
      - XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
      - JICOFO_COMPONENT_SECRET=jicofo_secret
      - JICOFO_AUTH_PASSWORD=focus_password
      - JVB_AUTH_USER=jvb
      - JVB_AUTH_PASSWORD=jvb_password
      - ENABLE_AUTH=1
      - ENABLE_GUESTS=0
      - AUTH_TYPE=internal
      # Matrix webhook notification module
      - XMPP_MUC_MODULES=matrix_webhook
      - MATRIX_WEBHOOK_URL=http://jitsi-bot:3001/webhook
      - MATRIX_WEBHOOK_SECRET={{ matrix_webhook_secret }}
      # Trust Docker subnets so Prosody uses X-Forwarded-For for real client IPs
      - PROSODY_TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8
    volumes:
      - /opt/services/jitsi/prosody/config:/config
      - /opt/services/jitsi/prosody/prosody-plugins-custom:/prosody-plugins-custom
    networks:
      - services

  jitsi-jicofo:
    image: "{{ jitsi_jicofo_image }}"
    container_name: jitsi-jicofo
    restart: unless-stopped
    environment:
      - XMPP_DOMAIN=meet.jitsi
      - XMPP_AUTH_DOMAIN=auth.meet.jitsi
      - XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
      - XMPP_SERVER=jitsi-prosody
      - JICOFO_COMPONENT_SECRET=jicofo_secret
      - JICOFO_AUTH_USER=focus
      - JICOFO_AUTH_PASSWORD=focus_password
    networks:
      - services

  jitsi-jvb:
    image: "{{ jitsi_jvb_image }}"
    container_name: jitsi-jvb
    restart: unless-stopped
    ports:
      - "10000:10000/udp"
    environment:
      - XMPP_AUTH_DOMAIN=auth.meet.jitsi
      - XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
      - XMPP_SERVER=jitsi-prosody
      - JVB_AUTH_USER=jvb
      - JVB_AUTH_PASSWORD=jvb_password
      - JVB_STUN_SERVERS=meet-jit-si-turnrelay.jitsi.net:443
      - JVB_PORT=10000
      - PUBLIC_URL=https://meet.{{ domain_name }}
    networks:
      - services

  matrix-postgres:
    image: "{{ matrix_postgres_image }}"
    container_name: matrix-postgres
    restart: unless-stopped
    environment:
      - POSTGRES_DB=synapse
      - POSTGRES_USER=synapse
      - POSTGRES_PASSWORD={{ postgres_password }}
      - POSTGRES_INITDB_ARGS=--encoding=UTF-8 --lc-collate=C --lc-ctype=C
    volumes:
      - /opt/services/matrix/postgres:/var/lib/postgresql/data
    networks:
      - services

  matrix-synapse:
    image: "{{ matrix_synapse_image }}"
    container_name: matrix-synapse
    restart: unless-stopped
    environment:
      - SYNAPSE_SERVER_NAME={{ domain_name }}
      - SYNAPSE_REPORT_STATS=no
      - SYNAPSE_ENABLE_REGISTRATION=no
      - SYNAPSE_REGISTRATION_SHARED_SECRET={{ matrix_registration_secret }}
      - POSTGRES_HOST=matrix-postgres
      - POSTGRES_USER=synapse
      - POSTGRES_PASSWORD={{ postgres_password }}
      - POSTGRES_DB=synapse
    volumes:
      - /opt/services/matrix/synapse:/data
    networks:
      - services
    labels:
      - "traefik.enable=true"
      # Client API (port 8008)
      - "traefik.http.routers.matrix.rule=Host(`matrix.{{ domain_name }}`)"
      - "traefik.http.routers.matrix.entrypoints=websecure"
      - "traefik.http.routers.matrix.service=matrix"
      - "traefik.http.services.matrix.loadbalancer.server.port=8008"
      - "traefik.http.services.matrix.loadbalancer.server.scheme=http"
      - "traefik.http.routers.matrix.tls.certresolver=letsencrypt"
      # Federation API (port 8448)
      - "traefik.http.routers.matrix-federation.rule=Host(`matrix.{{ domain_name }}`)"
      - "traefik.http.routers.matrix-federation.entrypoints=federation"
      - "traefik.http.routers.matrix-federation.service=matrix-federation"
      - "traefik.http.services.matrix-federation.loadbalancer.server.port=8008"
      - "traefik.http.routers.matrix-federation.tls.certresolver=letsencrypt"
      - "traefik.http.middlewares.upload-limit.buffering.maxRequestBodyBytes=1073741824"
      - "traefik.http.routers.matrix.middlewares=upload-limit"
    depends_on:
      - matrix-postgres

  element-web:
    image: "{{ element_web_image }}"
    container_name: element-web
    restart: unless-stopped
    volumes:
      - /opt/services/matrix/element/config.json:/app/config.json:ro
    networks:
      - services
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.element.rule=Host(`chat.{{ domain_name }}`)"
      - "traefik.http.routers.element.entrypoints=websecure"
      - "traefik.http.services.element.loadbalancer.server.port=80"
      - "traefik.http.services.element.loadbalancer.server.scheme=http"
      - "traefik.http.routers.element.tls.certresolver=letsencrypt"

  well-known:
    image: nginx:alpine
    container_name: well-known
    restart: unless-stopped
    volumes:
      - /opt/services/well-known:/usr/share/nginx/html/.well-known:ro
    networks:
      - services
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.wellknown.rule=(Host(`{{ domain_name }}`) || Host(`matrix.{{ domain_name }}`)) && PathPrefix(`/.well-known/`)"
      - "traefik.http.routers.wellknown.entrypoints=websecure"
      - "traefik.http.services.wellknown.loadbalancer.server.port=80"
      - "traefik.http.routers.wellknown.tls.certresolver=letsencrypt"

  routemaker:
    build:
      context: /opt/services/routemaker
      dockerfile: Dockerfile
    image: routemaker:latest
    container_name: routemaker
    restart: unless-stopped
    environment:
      - PORT=3000
      - NODE_ENV=production
      - SESSION_SECRET={{ lookup('password', '/dev/null chars=ascii_letters,digits length=32') }}
{% if security_bot_password is defined and security_bot_password != '' %}
      - SECURITY_BOT_WEBHOOK_URL=http://security-bot:3002/webhook/routemaker
      - SECURITY_BOT_SECRET={{ security_webhook_secret }}
{% endif %}
    volumes:
      - /opt/services/routemaker/data:/app/data
    networks:
      - services
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.routemaker.rule=Host(`maker.{{ domain_name }}`)"
      - "traefik.http.routers.routemaker.entrypoints=websecure"
      - "traefik.http.routers.routemaker.tls=true"
      - "traefik.http.routers.routemaker.tls.certresolver=letsencrypt"
      - "traefik.http.services.routemaker.loadbalancer.server.port=3000"

  jitsi-bot:
    build:
      context: /opt/services/bots/jitsi-bot
      dockerfile: Dockerfile
    image: jitsi-bot:latest
    container_name: jitsi-bot
    restart: unless-stopped
    environment:
      - BOT_USERNAME={{ matrix_bot_user }}
      - BOT_PASSWORD={{ matrix_bot_password }}
      - MATRIX_DOMAIN={{ domain_name }}
      - MATRIX_INTERNAL_URL=http://matrix-synapse:8008
      - JITSI_PUBLIC_URL=https://meet.{{ domain_name }}
      - WEBHOOK_SECRET={{ matrix_webhook_secret }}
      - MATRIX_ROOM={{ matrix_bot_room | default('') }}
    networks:
      - services
    depends_on:
      - matrix-synapse
      - jitsi-prosody

{% if security_bot_password is defined and security_bot_password != '' %}
  security-bot:
    build:
      context: /opt/services/bots/security-bot
      dockerfile: Dockerfile
    image: security-bot:latest
    container_name: security-bot
    restart: unless-stopped
    environment:
      - BOT_USERNAME={{ security_bot_user }}
      - BOT_PASSWORD={{ security_bot_password }}
      - MATRIX_DOMAIN={{ domain_name }}
      - MATRIX_INTERNAL_URL=http://matrix-synapse:8008
      - WEBHOOK_SECRET={{ security_webhook_secret }}
      - MATRIX_ROOM={{ security_bot_room | default('') }}
      - ADMIN_USER={{ matrix_admin_user | default('') and '@' + matrix_admin_user + ':' + domain_name }}
      - GEOIP_DB_PATH=/data/GeoLite2-City.mmdb
      - ALERT_ON_SUCCESS=true
      - RATE_LIMIT_WINDOW=300
      - POLL_INTERVAL=30
    volumes:
      # Host log files for SSH and WireGuard kernel events (read-only)
      - /var/log/auth.log:/var/log/auth.log:ro
      - /var/log/syslog:/var/log/syslog:ro
      # Synapse access logs for Matrix login monitoring (read-only)
      - /opt/services/matrix/synapse:/synapse-logs:ro
      # Docker socket for WireGuard peer polling and container event monitoring
      - /var/run/docker.sock:/var/run/docker.sock:ro
      # Persistent data directory (GeoLite2-City.mmdb lives here)
      - /opt/services/bots/security-bot/data:/data
    networks:
      - services
    depends_on:
      - matrix-synapse
{% endif %}

  mailserver:
    image: docker.io/mailserver/docker-mailserver:latest
    container_name: mailserver
    hostname: mail.{{ domain_name }}
    restart: unless-stopped
    ports:
      - "25:25"    # SMTP
      - "587:587"  # SMTP Submission (STARTTLS)
      - "465:465"  # SMTPS (SSL/TLS)
    volumes:
      - /opt/services/mailserver/mail-data:/var/mail
      - /opt/services/mailserver/mail-state:/var/mail-state
      - /opt/services/mailserver/mail-logs:/var/log/mail
      - /opt/services/mailserver/config:/tmp/docker-mailserver
      - /opt/services/traefik/acme:/etc/letsencrypt:ro
    environment:
      - OVERRIDE_HOSTNAME=mail.{{ domain_name }}
      - POSTMASTER_ADDRESS=postmaster@{{ domain_name }}
      - ENABLE_SPF=1
      - ENABLE_OPENDKIM=1
      - ENABLE_OPENDMARC=1
      - ENABLE_SPAMASSASSIN=1
      - SPAMASSASSIN_SPAM_TO_INBOX=1
      - ENABLE_FAIL2BAN=1
      - FAIL2BAN_BLOCKTYPE=drop
      - SSL_TYPE=manual
      - SSL_CERT_PATH=/etc/letsencrypt/acme.json
      - SSL_KEY_PATH=/etc/letsencrypt/acme.json
      - PERMIT_DOCKER=network
      - ONE_DIR=1
      - DMS_DEBUG=0
      - ENABLE_POP3=0
      - ENABLE_CLAMAV=0
      - ENABLE_POSTGREY=0
      - SMTP_ONLY=1
    cap_add:
      - NET_ADMIN
    networks:
      - services
    labels:
      - "traefik.enable=false"

networks:
  services:
    name: services_network
    driver: bridge
